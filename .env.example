# =============================================
# E-Commerce Platform — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.

# Server
PORT=3000

# Database — PostgreSQL connection string
# Local example: postgresql://postgres:password@localhost:5432/ecommerce_db
# Cloud (Neon, Supabase, etc.): postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# JWT — Access Token
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters
JWT_EXPIRES_IN=900          # Access token expiry in seconds (900 = 15 minutes)

# JWT — Refresh Token (use a DIFFERENT secret from JWT_SECRET)
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_32_characters

# CORS — Comma-separated list of allowed frontend origins (or * for all)
CORS_ORIGIN=http://localhost:3001
